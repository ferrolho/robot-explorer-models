<?xml version='1.0' encoding='utf-8'?>
<ns0:COLLADA xmlns:ns0="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <ns0:asset>
    <ns0:contributor>
      <ns0:author>Blender User</ns0:author>
      <ns0:authoring_tool>Blender 2.82.7 commit date:2020-02-12, commit time:16:20, hash:77d23b0bd76f</ns0:authoring_tool>
    </ns0:contributor>
    <ns0:created>2020-02-20T10:55:16</ns0:created>
    <ns0:modified>2020-02-20T10:55:16</ns0:modified>
    <ns0:unit name="meter" meter="1" />
    <ns0:up_axis>Z_UP</ns0:up_axis>
  </ns0:asset>
  <ns0:library_effects>
    <ns0:effect id="depth_camera-effect">
      <ns0:profile_COMMON>
        <ns0:newparam sid="depth_camera-surface">
          <ns0:surface type="2D">
            <ns0:init_from>depth_camera</ns0:init_from>
          </ns0:surface>
        </ns0:newparam>
        <ns0:newparam sid="depth_camera-sampler">
          <ns0:sampler2D>
            <ns0:source>depth_camera-surface</ns0:source>
          </ns0:sampler2D>
        </ns0:newparam>
        <ns0:technique sid="common">
          <ns0:lambert>
            <ns0:emission>
              <ns0:color sid="emission">0 0 0 1</ns0:color>
            </ns0:emission>
            <ns0:diffuse>
              <ns0:texture texture="depth_camera-sampler" texcoord="UVMap" />
            </ns0:diffuse>
            <ns0:index_of_refraction>
              <ns0:float sid="ior">1.45</ns0:float>
            </ns0:index_of_refraction>
          </ns0:lambert>
        </ns0:technique>
      </ns0:profile_COMMON>
    </ns0:effect>
  </ns0:library_effects>
  <ns0:library_images>
    <ns0:image id="depth_camera" name="depth_camera">
      <ns0:init_from>depth_camera.jpg</ns0:init_from>
    </ns0:image>
  </ns0:library_images>
  <ns0:library_materials>
    <ns0:material id="depth_camera-material" name="depth_camera">
      <ns0:instance_effect url="#depth_camera-effect" />
    </ns0:material>
  </ns0:library_materials>
  <ns0:library_geometries>
    <ns0:geometry id="Cube-mesh" name="Cube">
      <ns0:mesh>
        <ns0:source id="Cube-mesh-positions">
          <ns0:float_array id="Cube-mesh-positions-array" count="24">0 -0.04699999 -0.01968461 0 -0.04699999 0.01951932 0 0.04699999 -0.01968461 0 0.04699999 0.01951932 0.03039997 -0.04699999 -0.01968461 0.03039997 -0.04699999 0.01951932 0.03039997 0.04699999 -0.01968461 0.03039997 0.04699999 0.01951932</ns0:float_array>
          <ns0:technique_common>
            <ns0:accessor source="#Cube-mesh-positions-array" count="8" stride="3">
              <ns0:param name="X" type="float" />
