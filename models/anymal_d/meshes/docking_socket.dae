  <ns0:library_effects>
    <ns0:effect id="docking_socket-effect">
      <ns0:profile_COMMON>
        <ns0:newparam sid="docking_socket-surface">
          <ns0:surface type="2D">
            <ns0:init_from>docking_socket</ns0:init_from>
          </ns0:surface>
        </ns0:newparam>
        <ns0:newparam sid="docking_socket-sampler">
          <ns0:sampler2D>
            <ns0:source>docking_socket-surface</ns0:source>
          </ns0:sampler2D>
        </ns0:newparam>
        <ns0:technique sid="common">
          <ns0:lambert>
            <ns0:emission>
              <ns0:color sid="emission">0 0 0 1</ns0:color>
            </ns0:emission>
            <ns0:diffuse>
              <ns0:texture texture="docking_socket-sampler" texcoord="UVMap" />
            </ns0:diffuse>
            <ns0:index_of_refraction>
              <ns0:float sid="ior">1.45</ns0:float>
            </ns0:index_of_refraction>
          </ns0:lambert>
        </ns0:technique>
      </ns0:profile_COMMON>
    </ns0:effect>
  </ns0:library_effects>
