    </ns0:contributor>
    <ns0:created>2015-07-20T12:17:06</ns0:created>
    <ns0:modified>2015-07-20T12:17:06</ns0:modified>
    <ns0:unit name="meter" meter="1" />
    <ns0:up_axis>Z_UP</ns0:up_axis>
  </ns0:asset>
  <ns0:library_images>
    <ns0:image id="whiteTexture_png" name="whiteTexture_png">
      <ns0:init_from>whiteTexture.png</ns0:init_from>
    </ns0:image>
  </ns0:library_images>
  <ns0:library_effects>
    <ns0:effect id="Material-effect">
      <ns0:profile_COMMON>
        <ns0:newparam sid="whiteTexture_png-surface">
          <ns0:surface type="2D">
            <ns0:init_from>whiteTexture_png</ns0:init_from>
          </ns0:surface>
        </ns0:newparam>
        <ns0:newparam sid="whiteTexture_png-sampler">
          <ns0:sampler2D>
            <ns0:source>whiteTexture_png-surface</ns0:source>
          </ns0:sampler2D>
        </ns0:newparam>
        <ns0:technique sid="common">
          <ns0:phong>
            <ns0:emission>
              <ns0:color sid="emission">0 0 0 1</ns0:color>
            </ns0:emission>
            <ns0:ambient>
              <ns0:color sid="ambient">1 1 1 1</ns0:color>
            </ns0:ambient>
            <ns0:diffuse>
              <ns0:texture texture="whiteTexture_png-sampler" texcoord="UVMap" />
            </ns0:diffuse>
            <ns0:specular>
              <ns0:color sid="specular">0.5 0.5 0.5 1</ns0:color>
            </ns0:specular>
            <ns0:shininess>
              <ns0:float sid="shininess">50</ns0:float>
            </ns0:shininess>
            <ns0:index_of_refraction>
              <ns0:float sid="index_of_refraction">1</ns0:float>
            </ns0:index_of_refraction>
          </ns0:phong>
        </ns0:technique>
      </ns0:profile_COMMON>
    </ns0:effect>
  </ns0:library_effects>
  <ns0:library_materials>
    <ns0:material id="Material-material" name="Material">
      <ns0:instance_effect url="#Material-effect" />
    </ns0:material>
  </ns0:library_materials>
