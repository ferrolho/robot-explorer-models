        <ns0:triangles material="depth_camera-material" count="12">
          <ns0:input semantic="VERTEX" source="#Cube-mesh-vertices" offset="0" />
          <ns0:input semantic="NORMAL" source="#Cube-mesh-normals" offset="1" />
          <ns0:input semantic="TEXCOORD" source="#Cube-mesh-map" offset="2" set="0" />
