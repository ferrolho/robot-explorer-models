<?xml version='1.0' encoding='utf-8'?>
<ns0:COLLADA xmlns:ns0="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <ns0:asset>
    <ns0:contributor>
      <ns0:author>Blender User</ns0:author>
      <ns0:authoring_tool>Blender 2.93.0 commit date:2021-06-02, commit time:11:21, hash:84da05a8b806</ns0:authoring_tool>
    </ns0:contributor>
    <ns0:created>2021-06-16T11:05:15</ns0:created>
    <ns0:modified>2021-06-16T11:05:15</ns0:modified>
    <ns0:unit name="meter" meter="1" />
    <ns0:up_axis>Z_UP</ns0:up_axis>
  </ns0:asset>
  <ns0:library_effects>
    <ns0:effect id="battery-effect">
      <ns0:profile_COMMON>
        <ns0:newparam sid="battery-surface">
          <ns0:surface type="2D">
            <ns0:init_from>battery</ns0:init_from>
          </ns0:surface>
        </ns0:newparam>
        <ns0:newparam sid="battery-sampler">
          <ns0:sampler2D>
            <ns0:source>battery-surface</ns0:source>
          </ns0:sampler2D>
        </ns0:newparam>
        <ns0:technique sid="common">
          <ns0:lambert>
            <ns0:emission>
              <ns0:color sid="emission">0 0 0 1</ns0:color>
            </ns0:emission>
            <ns0:diffuse>
              <ns0:texture texture="battery-sampler" texcoord="UVMap" />
            </ns0:diffuse>
            <ns0:index_of_refraction>
              <ns0:float sid="ior">1.45</ns0:float>
            </ns0:index_of_refraction>
          </ns0:lambert>
        </ns0:technique>
      </ns0:profile_COMMON>
    </ns0:effect>
  </ns0:library_effects>
  <ns0:library_images>
    <ns0:image id="battery" name="battery">
      <ns0:init_from>battery.jpg</ns0:init_from>
    </ns0:image>
  </ns0:library_images>
  <ns0:library_materials>
    <ns0:material id="battery-material" name="battery">
      <ns0:instance_effect url="#battery-effect" />
    </ns0:material>
  </ns0:library_materials>
